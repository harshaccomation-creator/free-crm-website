# Supabase Configuration
# Frontend (Vite uses these prefixed with VITE_ or NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend (Node.js server uses these)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email Service (Resend)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=SalesFlow Hub <onboarding@resend.dev>
OTP_FROM_EMAIL=SalesFlow Hub <onboarding@resend.dev>

# OTP Configuration
OTP_SECRET=your-otp-secret-here

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace placeholder values with your actual Supabase and Resend credentials
# 3. Get credentials from: https://supabase.com/dashboard
# 4. Backend uses: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY
# 5. Frontend uses: NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY
